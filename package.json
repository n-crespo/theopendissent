  "main": "index.ts",
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@tailwindcss/postcss": "^4.2.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "firebase-tools": "^15.15.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "framer-motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:all": "vitest run tests/",
    "test": "firebase emulators:exec --only database,auth --project=the-open-dissent-prod \"pnpm test:all\"",
    "test:rules": "firebase emulators:exec --only database,auth --project=the-open-dissent-prod \"vitest run tests/database.rules.test.ts\"",
    "test:integration": "firebase emulators:exec --only database,auth --project=the-open-dissent-prod \"vitest run tests/integration.test.ts\"",
    "test:deletion": "firebase emulators:exec --only database,auth --project=the-open-dissent-prod \"vitest run tests/account-deletion.test.ts\"",
    "functions:watch": "npm run --prefix functions build:watch",
    "emulate:new": "firebase emulators:start --project=the-open-dissent-prod --export-on-exit=./firebase-data",
    "emulate": "firebase emulators:start --project=the-open-dissent-prod --import=./firebase-data --export-on-exit=./firebase-data"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n-crespo/theopendissent.git"
  },
