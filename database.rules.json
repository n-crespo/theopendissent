{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "notifications": {
          ".indexOn": [
            "updatedAt"
          ],
          ".read": "auth != null && auth.uid === $uid",
          "$notification_id": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['type', 'isRead', 'updatedAt'])",
            "type": {
              ".validate": "newData.isString()"
            },
            "count": {
              ".validate": "newData.isNumber()"
            },
            "isRead": {
              ".validate": "newData.isBoolean()"
            },
            "createdAt": {
              ".validate": "newData.isNumber()"
            },
            "updatedAt": {
              ".validate": "newData.isNumber()"
            }
          }
        },
        "posts": {
          "$post_id": {
            ".validate": "newData.val() === true"
          }
        },
        "replies": {
          "$post_id": {
            "$reply_id": {
              ".validate": "newData.val() === true"
            }
          }
        },
        "postInteractions": {
          "$post_id": {
            ".validate": "newData.hasChildren(['score', 'parentId'])",
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= -3 && newData.val() <= 3"
            },
            "parentId": {
              ".validate": "newData.isString()"
            }
          }
        }
      }
    },
    "posts": {
      ".indexOn": [
        "timestamp"
      ],
      ".read": true,
      "$post_id": {
        ".write": "auth != null && ( (!data.exists() && newData.parent().parent().child('users/'+auth.uid+'/posts/'+$post_id).exists()) || (data.exists() && (data.child('userId').val() === auth.uid || root.child('users/'+auth.uid+'/posts/'+$post_id).exists())) )",
        ".validate": "!newData.exists() || (data.exists() || newData.hasChildren(['postContent', 'timestamp', 'replyCount']))",
        "replyCount": {
          ".write": false,
          ".validate": "newData.isNumber()"
        },
        "userInteractions": {
          ".write": false
        },
        "userId": {
          ".validate": "!newData.exists() || (newData.val() === auth.uid && (!data.exists() || data.val() === newData.val()))"
        },
        "postContent": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 600)"
        },
        "timestamp": {
          ".validate": "!data.exists() || data.val() === newData.val()"
        },
        "editedAt": {
          ".validate": "!newData.exists() || newData.isNumber()"
        }
      }
    },
    "replies": {
      "$post_id": {
        ".indexOn": [
          "timestamp"
        ],
        ".read": true,
        ".write": "auth != null && (root.child('posts/' + $post_id + '/userId').val() === auth.uid || root.child('users/' + auth.uid + '/posts/' + $post_id).exists())",
        "$reply_id": {
          ".write": "auth != null && ( (!data.exists() && (newData.child('interactionScore').isNumber() || root.child('posts/' + $post_id + '/userInteractions/' + auth.uid).exists() || root.child('posts/' + $post_id + '/userId').val() === auth.uid || root.child('users/' + auth.uid + '/posts/' + $post_id).exists()) && newData.parent().parent().parent().child('users/' + auth.uid + '/replies/' + $post_id + '/' + $reply_id).exists()) || (data.exists() && (data.child('userId').val() === auth.uid || root.child('users/' + auth.uid + '/replies/' + $post_id + '/' + $reply_id).exists())) )",
          ".validate": "!newData.exists() || (data.exists() || newData.hasChildren(['postContent', 'timestamp', 'parentPostId', 'interactionScore', 'replyCount']))",
          "userInteractions": {
            ".write": false
          },
          "replyCount": {
            ".write": false,
            ".validate": "newData.isNumber()"
          },
          "userId": {
            ".validate": "!newData.exists() || newData.val() === auth.uid"
          },
          "parentPostId": {
            ".validate": "!newData.exists() || newData.val() === $post_id"
          },
          "postContent": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 600)"
          },
          "interactionScore": {
            ".validate": "newData.isNumber() && newData.val() >= -3 && newData.val() <= 3"
          },
          "timestamp": {
            ".validate": "!data.exists() || data.val() === newData.val()"
          },
          "editedAt": {
            ".validate": "!newData.exists() || newData.isNumber()"
          }
        }
      }
    }
  }
}
